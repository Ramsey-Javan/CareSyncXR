//  DB 
docker exec -it caresync-backend-db-1 psql -U postgres -d caresync

\d -> List all tables (the "Data Tables" view).
\dt -> Describe a table (shows columns, types, and constraints/foreign keys).
\dn -> List all schemas.
\du -> List all users (roles).
\q -> Quit and exit the psql terminal.

SELECT id, email, role, full_name FROM users;
